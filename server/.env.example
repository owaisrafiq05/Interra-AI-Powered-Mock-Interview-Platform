NODE_ENV=development
PORT=5000

# MongoDB Atlas (cloud) — Database → Connect → Drivers → copy URI
# Replace <password> and set a database name (e.g. /interra). Use mongodb+srv://…
# Atlas → Network Access: allow your IP (or 0.0.0.0/0 for hackathon demos only).
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/interra?retryWrites=true&w=majority

# Legacy self-hosted (optional alternative to MONGODB_URI)
# MONGO_URI=mongodb://127.0.0.1:27017/interra

# Auth (use either pair; code accepts both)
ACCESS_TOKEN_SECRET=change-me-long-random-string
ACCESS_TOKEN_EXPIRY=15d
JWT_SECRET=

# AI
GEMINI_API_KEY=
# Optional override (see https://ai.google.dev/gemini-api/docs/models )
GEMINI_MODEL=gemini-2.5-flash

# Transcription: default local (openai-whisper). Use TRANSCRIPTION_PROVIDER=openai for OpenAI Whisper API.
# Local: python3 -m venv .venv-whisper && . .venv-whisper/bin/activate && pip install -r requirements-whisper.txt
# Optional: WHISPER_PYTHON=/abs/path/to/.venv-whisper/bin/python  (auto-detected if .venv-whisper exists under server/)
# ffmpeg: sudo apt install ffmpeg — https://github.com/openai/whisper
TRANSCRIPTION_PROVIDER=local
OPENAI_API_KEY=
# WHISPER_PYTHON=
# WHISPER_LOCAL_MODEL=base
# WHISPER_LOCAL_DEVICE=cpu
# WHISPER_LOCAL_TIMEOUT_MS=600000

# Local audio uploads before Whisper (see technical plan)
UPLOAD_DIR=
