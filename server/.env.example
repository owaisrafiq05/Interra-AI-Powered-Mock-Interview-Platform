NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/interra

# Auth (use either pair; code accepts both)
ACCESS_TOKEN_SECRET=change-me-long-random-string
ACCESS_TOKEN_EXPIRY=15d
JWT_SECRET=

# AI
GEMINI_API_KEY=
# Optional override, e.g. gemini-1.5-flash or gemini-2.0-flash
GEMINI_MODEL=gemini-1.5-flash
OPENAI_API_KEY=

# Local audio uploads before Whisper (see technical plan)
UPLOAD_DIR=
